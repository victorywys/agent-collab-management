#!/bin/bash

# Create Agent Collab Repository Skill
# Automatically creates new repositories with agent collaboration system

set -e  # Exit on any error

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
AGENT_COLLAB_MANAGEMENT_REPO="https://github.com/victorywys/agent-collab-management.git"
DEFAULT_PROJECT_TYPE="generic"

# Print colored output
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Show usage
show_usage() {
    cat << EOF
Create Agent Collab Repository

Usage: $0 <project-name> [project-type] [--github-user USERNAME]

Parameters:
  project-name     Name of the new repository (required)
  project-type     Type: generic|node|python|go|docs|config (default: generic)
  --github-user    GitHub username (optional, uses git config if not set)

Examples:
  $0 my-new-project
  $0 api-service node --github-user victorywys
  $0 project-docs docs
  $0 ml-toolkit python

Project Types:
  generic    Basic repository with coordination system
  node       Node.js/JavaScript project with npm setup
  python     Python project with pip/setup.py
  go         Go project with go.mod
  docs       Documentation project with markdown focus
  config     Configuration/dotfiles project
EOF
}

# Validate project name
validate_project_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        print_error "Invalid project name. Use only letters, numbers, hyphens, and underscores."
        exit 1
    fi

    if [ -d "$name" ]; then
        print_error "Directory '$name' already exists."
        exit 1
    fi
}

# Check prerequisites
check_prerequisites() {
    print_status "Checking prerequisites..."

    # Check git
    if ! command -v git &> /dev/null; then
        print_error "Git is not installed."
        exit 1
    fi

    # Check GitHub CLI
    if ! command -v gh &> /dev/null; then
        print_error "GitHub CLI (gh) is not installed. Install it from https://cli.github.com/"
        exit 1
    fi

    # Check GitHub authentication
    if ! gh auth status &> /dev/null; then
        print_error "GitHub CLI is not authenticated. Run 'gh auth login' first."
        exit 1
    fi

    # Check git configuration
    if ! git config --global user.name &> /dev/null || ! git config --global user.email &> /dev/null; then
        print_warning "Git user configuration not set globally."
        print_status "You may need to configure git user info for this repository."
    fi

    print_success "Prerequisites check passed."
}

# Create project directory and initialize git
setup_repository() {
    local project_name="$1"

    print_status "Creating repository: $project_name"

    mkdir "$project_name"
    cd "$project_name"

    # Initialize git
    git init
    git branch -M main

    # Set up git configuration if needed
    local git_name=$(git config --global user.name 2>/dev/null || echo "")
    local git_email=$(git config --global user.email 2>/dev/null || echo "")

    if [ -z "$git_name" ] || [ -z "$git_email" ]; then
        print_status "Setting up git configuration for this repository..."
        if [ -z "$git_name" ]; then
            git config user.name "Agent Collab User"
        fi
        if [ -z "$git_email" ]; then
            git config user.email "agent@example.com"
        fi
    fi

    print_success "Repository initialized: $project_name"
}

# Download and set up agent coordination system
setup_coordination_system() {
    print_status "Setting up agent coordination system..."

    # Create temporary directory for cloning
    local temp_dir=$(mktemp -d)

    # Clone the management repository
    git clone "$AGENT_COLLAB_MANAGEMENT_REPO" "$temp_dir/agent-collab-management"

    # Copy coordination system files
    cp -r "$temp_dir/agent-collab-management/.claude" ./

    # Make scripts executable
    chmod +x .claude/*.sh .claude/*.fish

    # Clean up temporary directory
    rm -rf "$temp_dir"

    print_success "Agent coordination system installed."
}

