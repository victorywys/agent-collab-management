# Create GitHub repository and push
setup_github_repository() {
    local project_name="$1"
    local github_user="$2"

    print_status "Creating GitHub repository..."

    # Create initial commit
    git add .
    git commit -m "Initial commit: $project_name with Agent Collab coordination

- Multi-agent coordination system enabled
- Professional project structure
- Ready for collaborative development
- Generated by create-agent-collab-repo skill"

    # Create GitHub repository
    if [ -n "$github_user" ]; then
        gh repo create "$github_user/$project_name" --public --source=. --remote=origin --push
    else
        gh repo create "$project_name" --public --source=. --remote=origin --push
    fi

    print_success "GitHub repository created and initial commit pushed."
}

# Test coordination system
test_coordination_system() {
    print_status "Testing coordination system..."

    # Source the helpers and test
    if [ -f .claude/agent-coordination-helpers.sh ]; then
        source .claude/agent-coordination-helpers.sh
        print_success "Coordination system is active!"
        echo
        print_status "Available coordination commands:"
        echo "  - claude-agents-log"
        echo "  - claude-agents-active"
        echo "  - claude-agents-today"
        echo "  - claude-agents-search <keyword>"
        echo "  - claude-agents-stats"
        echo "  - claude-agents-cleanup"
    else
        print_error "Coordination system not found!"
    fi
}

# Main function
main() {
    local project_name=""
    local project_type="$DEFAULT_PROJECT_TYPE"
    local github_user=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --github-user)
                github_user="$2"
                shift 2
                ;;
            -h|--help)
                show_usage
                exit 0
                ;;
            *)
                if [ -z "$project_name" ]; then
                    project_name="$1"
                elif [[ "$1" =~ ^(generic|node|python|go|docs|config)$ ]]; then
                    project_type="$1"
                else
                    print_error "Unknown argument: $1"
                    show_usage
                    exit 1
                fi
                shift
                ;;
        esac
    done

    # Validate required arguments
    if [ -z "$project_name" ]; then
        print_error "Project name is required."
        show_usage
        exit 1
    fi

    # Validate project name
    validate_project_name "$project_name"

    # Check prerequisites
    check_prerequisites

    print_status "Creating Agent Collab repository: $project_name (type: $project_type)"

    # Create and set up repository
    setup_repository "$project_name"
    setup_coordination_system
    generate_gitignore "$project_type"
    generate_readme "$project_name" "$project_type" "$github_user"
    generate_project_files "$project_type" "$project_name"

    # Set up GitHub
    setup_github_repository "$project_name" "$github_user"

    # Test coordination system
    test_coordination_system

    echo
    print_success "🎉 Agent Collab repository '$project_name' created successfully!"
    print_status "Repository location: $(pwd)"
    print_status "GitHub URL: $(git config --get remote.origin.url | sed 's/git@github.com:/https:\/\/github.com\//' | sed 's/\.git$//')"
    echo
    print_status "Next steps:"
    echo "  1. cd $project_name"
    echo "  2. source .claude/agent-coordination-helpers.sh"
    echo "  3. Start collaborating with: claude-agents-log"
}

# Run main function
main "$@"